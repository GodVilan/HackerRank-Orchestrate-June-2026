# Copy to code/.env and fill in. code/.env is git-ignored and must NEVER be committed.
# Secrets are read from the environment only (see code/config.py). No key is hardcoded.

# Required: Anthropic API key for the Claude workhorse + escalation tiers.
ANTHROPIC_API_KEY=

# Optional: only needed if you enable the Gemini hybrid path
# (config.ENABLE_GEMINI_HYBRID = True). Leave blank otherwise.
GEMINI_API_KEY=
